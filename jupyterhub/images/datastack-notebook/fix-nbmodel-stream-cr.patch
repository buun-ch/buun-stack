 from jupyter_server_nbmodel.event_logger import event_logger
 
 
+def _apply_carriage_return(text: str) -> str:
+    """Apply carriage return processing to simulate terminal behavior.
+
+    Handles \\r characters by overwriting from the beginning of the line,
+    matching how terminals render tqdm progress bars.
+    """
+    lines = text.split("\n")
+    result = []
+    for line in lines:
+        if "\r" in line:
+            parts = line.split("\r")
+            visible = parts[0]
+            for part in parts[1:]:
+                if not part:
+                    visible = ""
+                elif len(part) >= len(visible):
+                    visible = part
+                else:
+                    visible = part + visible[len(part):]
+            result.append(visible)
+        else:
+            result.append(line)
+    return "\n".join(result)
+
